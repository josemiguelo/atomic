#!/bin/bash

set -euo pipefail

# clone stellasaur repo
BASE_PATH="$HOME/Repos/gh/josemiguelo"
REPO_PATH="$BASE_PATH/stellasaur"
if [ ! -d "$REPO_PATH" ]; then
  echo "Cloning stellasaur repo into $REPO_PATH"
  mkdir -p "$BASE_PATH"
  git clone --recurse-submodules https://github.com/josemiguelo/stellasaur.git "$REPO_PATH"
else
  echo "Stellasaur repo already exists in $REPO_PATH"
fi

echo 'Post install checker done!'
