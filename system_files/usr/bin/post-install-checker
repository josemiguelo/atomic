#!/bin/bash

set -euo pipefail

# clone atomic repo
BASE_PATH="$HOME/Repos/gh/josemiguelo"
REPO_PATH="$BASE_PATH/atomic"
if [ ! -d "$REPO_PATH" ]; then
  echo "Cloning atomic repo into $REPO_PATH"
  mkdir -p "$BASE_PATH"
  git clone --recurse-submodules https://github.com/josemiguelo/atomic.git "$REPO_PATH"
else
  echo "atomic repo already exists in $REPO_PATH"
fi

DESIRED_REMOTE="git@github.com:josemiguelo/atomic.git"
CURRENT_REMOTE=$(cd "$REPO_PATH" && git remote get-url origin 2>/dev/null)
if [ "$CURRENT_REMOTE" != "$DESIRED_REMOTE" ]; then
  echo "🚀 Setting atomic git remote to $DESIRED_REMOTE..."
  (cd "$REPO_PATH" && git remote set-url origin "$DESIRED_REMOTE" && echo "✅ remote set successfully")
else
  echo "✅ atomic git remote is already set correctly."
fi

echo 'Post install checker done!'
